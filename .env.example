# Postgres connection string.
# Local (docker compose) uses the value below. For Neon, paste your pooled
# connection string and keep the sslmode param, e.g.:
#   postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/db?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/chat-with-your-docs

# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional
LOG_LEVEL=info
